% =====================================================================
%  CareerOS — CV template (your single-column style), tectonic / XeTeX
%  Compile:  tectonic <file>.tex
%
%  HOW build-cv.md FILLS THIS:
%   - Replace every <<UPPER_SNAKE>> placeholder with tailored, latex-escaped text.
%   - Repeat each block between  %% REPEAT X  and  %% END REPEAT X  once per item;
%     order/include by archetype relevance. Delete an optional section entirely if
%     empty. Leave NO literal <<...>> behind (compile-latex.mjs fails on leftovers).
%   - Keep ONE page if possible. Single column. Standard section headings.
%
%  VERIFIED ATS RULES (do not "fix"):
%   - fontspec + Latin Modern by FILENAME + Ligatures={NoCommon}: this is what
%     keeps "Airflow"/"workflow"/"classification" extractable as plain ASCII
%     (T1 fontenc alone emits fi/fl ligatures that ATS keyword search misses).
%   - Never add \input{glyphtounicode}/\pdfgentounicode/microtype DisableLigatures
%     (they ERROR under tectonic).
% =====================================================================
\documentclass[a4paper,10pt]{article}

\usepackage{fontspec}
\defaultfontfeatures{Ligatures={NoCommon}}
\setmainfont{lmroman10-regular}[
  Extension      = .otf,
  BoldFont       = lmroman10-bold,
  ItalicFont     = lmroman10-italic,
  BoldItalicFont = lmroman10-bolditalic ]

\usepackage[empty]{fullpage}
\usepackage{titlesec}
\usepackage[usenames,dvipsnames]{color}
\usepackage{enumitem}
\usepackage[hidelinks]{hyperref}
\usepackage{fancyhdr}

\pagestyle{fancy}
\fancyhf{}
\fancyfoot{}
\renewcommand{\headrulewidth}{0pt}
\renewcommand{\footrulewidth}{0pt}

% --- Margins ---
\addtolength{\oddsidemargin}{-0.7in}
\addtolength{\evensidemargin}{-0.7in}
\addtolength{\textwidth}{1.4in}
\addtolength{\topmargin}{-.70in}
\addtolength{\textheight}{1.45in}

\urlstyle{same}
\raggedbottom
\raggedright
\setlength{\tabcolsep}{0in}
\linespread{1.0}

% --- Section formatting ---
\titleformat{\section}{
  \vspace{-8pt}\scshape\raggedright\large
}{}{0em}{}[\color{black}\titlerule \vspace{-7pt}]

% --- Custom commands ---
\newcommand{\resumeSubheading}[4]{
  \vspace{-1pt}\item
    \begin{tabular*}{0.97\textwidth}{l@{\extracolsep{\fill}}r}
      \textbf{#1} & #2 \\
      \textit{\small#3} & \textit{\small #4} \\
    \end{tabular*}\vspace{-5pt}
}
\newcommand{\resumeSubHeadingListStart}{\begin{itemize}[leftmargin=*]}
\newcommand{\resumeSubHeadingListEnd}{\end{itemize}}

