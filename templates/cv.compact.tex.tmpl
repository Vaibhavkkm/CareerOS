% =====================================================================
%  CareerOS — CV template: "Compact" theme, tectonic / XeTeX
%  Compile:  tectonic <file>.tex
%
%  SAME placeholder contract + SAME sections as templates/cv.tex.tmpl. The ONLY
%  difference is density: wider text block, tighter margins, smaller inter-section
%  spacing — to fit a longer history on ONE page without dropping content. Use when
%  Classic spills onto a second page.
%
%  VERIFIED ATS RULES (do not "fix"): fontspec + Latin Modern by FILENAME +
%  Ligatures={NoCommon}; never add glyphtounicode/microtype DisableLigatures.
% =====================================================================
\documentclass[a4paper,10pt]{article}

\usepackage{fontspec}
\defaultfontfeatures{Ligatures={NoCommon}}
\setmainfont{lmroman10-regular}[
  Extension      = .otf,
  BoldFont       = lmroman10-bold,
  ItalicFont     = lmroman10-italic,
  BoldItalicFont = lmroman10-bolditalic ]

\usepackage[empty]{fullpage}
\usepackage{titlesec}
\usepackage[usenames,dvipsnames]{color}
\usepackage{enumitem}
\usepackage[hidelinks]{hyperref}
\usepackage{fancyhdr}

\pagestyle{fancy}
\fancyhf{}
\fancyfoot{}
\renewcommand{\headrulewidth}{0pt}
\renewcommand{\footrulewidth}{0pt}

% --- Margins: tighter than Classic to gain width + height ---
\addtolength{\oddsidemargin}{-0.8in}
\addtolength{\evensidemargin}{-0.8in}
\addtolength{\textwidth}{1.6in}
\addtolength{\topmargin}{-.85in}
\addtolength{\textheight}{1.7in}

\urlstyle{same}
\raggedbottom
\raggedright
\setlength{\tabcolsep}{0in}
\linespread{0.96}

% --- Section formatting: tighter vertical rhythm ---
\titleformat{\section}{
  \vspace{-10pt}\scshape\raggedright\large
}{}{0em}{}[\color{black}\titlerule \vspace{-9pt}]

\newcommand{\resumeSubheading}[4]{
  \vspace{-2pt}\item
    \begin{tabular*}{0.97\textwidth}{l@{\extracolsep{\fill}}r}
      \textbf{#1} & #2 \\
      \textit{\small#3} & \textit{\small #4} \\
    \end{tabular*}\vspace{-6pt}
}
\newcommand{\resumeSubHeadingListStart}{\begin{itemize}[leftmargin=*]}
\newcommand{\resumeSubHeadingListEnd}{\end{itemize}}

