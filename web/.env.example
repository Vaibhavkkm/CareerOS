# CareerOS web control panel — environment
# Copy to .env.local for local dev, or set these in your host's build/deploy config.

# Public/demo mode. When "1", the board is a READ-ONLY showcase: mutating actions
# (generate / fetch / scan / enqueue) are gated server-side (HTTP 403) and visitors
# get a "fork & run your own Claude Code" modal. Leave UNSET for a normal local install
# (full functionality). Must be set at BUILD time to reach the client bundle.
NEXT_PUBLIC_CAREEROS_PUBLIC=0

# Repo the fork-gate links to (Fork + Star). Defaults to the canonical CareerOS repo.
NEXT_PUBLIC_CAREEROS_REPO=https://github.com/Vaibhavkkm/CareerOS

# Optional: the server-side gate ALSO honours this non-public name, so enforcement
# works even if the public flag was only set at runtime (not inlined at build).
# CAREEROS_PUBLIC=1
