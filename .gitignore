# dependencies
node_modules/

# web app (isolated; has its OWN package.json so the root stays zero-dependency)
web/node_modules/
web/.next/
web/out/
web/next-env.d.ts
web/tsconfig.tsbuildinfo

# Python sidecar venv (job-board fetch via python-jobspy) — local, never committed
.venv/
__pycache__/
*.pyc

# tectonic build artifacts
*.aux
*.log
*.out
*.synctex.gz

# OS
.DS_Store

# Local env overrides & any secrets — never committed. The repo's checked-in
# web/.env holds only PUBLIC, non-secret config; per-machine overrides (and any
# future API keys) belong in *.local files, which stay out of this public repo.
.env.local
.env.*.local
web/.env.local
web/.env.*.local
*.key
*.pem

# ─────────────────────────────────────────────────────────────────────────────
# YOUR DATA & PII — never committed (this repo is PUBLIC)
# ─────────────────────────────────────────────────────────────────────────────
# Everything CareerOS generates or learns about you lives in data/ and contains
# personal info (name, email, phone, address, employers, your CV + letters). It
# stays on your machine. Back it up with your OWN private git remote, not this one.
# `node scripts/doctor.mjs --fix` recreates the empty data/ structure on a fresh
# clone, and templates/*.example.yml are your starting points.
data/

# Personal source documents kept at the repo root (your CV, drafts, etc.)
main.tex
*.pdf
*.docx
*.doc
